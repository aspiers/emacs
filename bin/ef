#!/bin/bash

create_frame=
while [ $# != 0 ]; do
    case "$1" in
        -c|--create-frame)
            create_frame=$1
            shift
            ;;
        *)
            break
            ;;
    esac
done

if [ $# = 0 ]; then
    set -- .
fi

here=$(pwd)

for file in "$@"; do
    if [[ $file =~ ^\.\.?/ ]]; then
        file="$here/$file"
    fi

    if [ -d "$file" ] && { [ -d "$file/.git" ] || [ -f "$file/.git" ]; }; then
        quick-emacs \
            --bg-if-poss $create_frame \
            --eval "(magit-status \"$file\")"
    else
        quick-emacs \
            --bg-if-poss $create_frame \
            --eval "(find-file-with-location \"$file\")"
    fi
done
